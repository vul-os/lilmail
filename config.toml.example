[server]
port = 3000
username_is_email = true
# Allow a host shell (e.g. Vulos OS) to embed LilMail as an iframe. Space-separated
# list of origins in CSP frame-ancestors syntax. Leave empty for same-origin only.
# Example for the Vulos OS shell:  frame_ancestors = "'self' http://localhost:8080"
frame_ancestors = ""
# Set to true when serving over HTTPS (direct [ssl] or TLS reverse proxy) to
# add the Secure flag to session cookies. Default false for local HTTP dev.
secure_cookies = false

[imap]
server = "mail.example.com"
port = 993
tls = true

[cache]
folder = "./cache"

[jwt]
secret = "your-secure-jwt-secret"

[encryption]
key = "your-32-character-encryption-key"

[smtp]
# If not specified, SMTP server will be derived from IMAP server
server = "mail.example.com"
port = 587
use_starttls = true


[ssl]
enabled = true
cert_file = "/etc/letsencrypt/live/yourdomain.com/fullchain.pem"
key_file = "/etc/letsencrypt/live/yourdomain.com/privkey.pem"
port = 443
http_port = 80
auto_redirect = true
domain = "yourdomain.com"
hsts_max_age = 31536000  # 1 year in seconds

# Optional: OAuth2 / OpenID Connect login. When enabled, a "Sign in with
# OAuth2" button appears on the login page. The access token is presented to
# IMAP and SMTP using the XOAUTH2 or OAUTHBEARER SASL mechanism. Password login
# keeps working when this is disabled.
[oauth2]
enabled = false
client_id = "lilmail"
client_secret = "your-oauth2-client-secret"      # leave empty for public PKCE clients
auth_url = "https://auth.example.com/application/o/authorize/"
token_url = "https://auth.example.com/application/o/token/"
# Optional. Used to look up the user's email. If omitted, the email is read
# from the id_token (request the "openid email" scopes).
userinfo_url = "https://auth.example.com/application/o/userinfo/"
redirect_url = "https://yourdomain.com/auth/oauth/callback"
scopes = ["openid", "email", "profile"]
mechanism = "xoauth2"     # "xoauth2" or "oauthbearer"
email_claim = "email"     # claim holding the email address
use_pkce = true           # PKCE (S256); recommended

# Optional: Phase-6 real-time notifications. Everything below is OPT-IN and
# DEFAULT-DISABLED. With enabled = false (the default) the application behaves
# exactly as before — no extra goroutines, no SSE route, no JS changes.
#
# To activate:
#   1. Set enabled = true.
#   2. Reload / restart the server.
#   3. Open LilMail in a browser and grant the Notifications permission when
#      prompted; new-mail browser toasts will then appear while the tab is open.
#
# [notifications]
# enabled = false   # master switch — must be true to activate anything
# idle    = true    # IMAP IDLE watcher (recommended; falls back to NOOP poll)
# desktop = false   # native OS toast via gen2brain/beeep (local/desktop runs)

# Optional: CalDAV calendar integration. Routes appear in the sidebar only when enabled.
#
# [caldav]
# enabled  = true
# url      = "https://cal.example.com/dav/"   # CalDAV endpoint or principal URL
# auth     = "basic"                           # "basic" or "oauth2"
# username = "alice@example.com"               # used when auth = "basic"
# password = "app-password"                    # used when auth = "basic"

# Optional: CardDAV address-book for recipient autocomplete in the compose modal.
# When enabled, the To/CC autocomplete also queries the configured address book.
#
# [carddav]
# enabled  = false
# url      = "https://dav.example.com"
# username = "alice@example.com"
# password = "secret"

# Optional: Mail AI assistant. Routes:
#   POST /api/ai/compose         — smart compose / continue / rewrite
#   POST /api/ai/summarize       — thread summary + key points + action items
#   POST /api/ai/reply           — 3 reply suggestions (concise / detailed / decline)
#   POST /api/ai/extract-actions — action items with optional due dates
#   POST /api/ai/phishing        — phishing / suspicious / clean classification
#
# All routes are gated on [ai] enabled. When false they return 404 {"error":"ai_disabled"}.
#
# The default endpoint is the Vulos OS airouter (/api/ai/chat) — no extra
# configuration needed when LilMail is embedded in a Vulos installation.
# For standalone use, point at any OpenAI-compatible SSE chat-completion API.
#
# [ai]
# enabled  = false
# endpoint = "http://localhost:8080/api/ai/chat"  # Vulos OS airouter (default)
# api_key  = ""    # Bearer token — leave empty for local Vulos airouter
# model    = ""    # model slug forwarded to endpoint; empty = endpoint default
