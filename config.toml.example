[server]
port = 3000
# Legacy alias for [auth] allow_full_email_username (kept for backwards
# compatibility). If [auth] allow_full_email_username is set, it takes
# precedence over this key.
username_is_email = true
# Allow a host shell (e.g. Vulos OS) to embed LilMail as an iframe. Space-separated
# list of origins in CSP frame-ancestors syntax. Leave empty for same-origin only.
# Example for the Vulos OS shell:  frame_ancestors = "'self' http://localhost:8080"
frame_ancestors = ""
# Set to true when serving over HTTPS (direct [ssl] or TLS reverse proxy) to
# add the Secure flag to session cookies. STRONGLY recommended for any
# internet-facing deployment; set to false only for plain-HTTP local dev.
secure_cookies = true

# Authentication / login preferences.
[auth]
# Controls what LilMail sends as the IMAP/SMTP login username.
#   true  → the FULL email address is used as the username (e.g.
#           "alice@example.com"). This is what most hosted providers expect
#           (Gmail, Fastmail, Migadu, Zoho, …) and is the default.
#   false → only the local part before "@" is sent (e.g. "alice"). Use this for
#           self-hosted Dovecot/Postfix setups that authenticate the bare handle.
# This takes precedence over the legacy [server] username_is_email key above.
allow_full_email_username = true

[imap]
server = "mail.example.com"
port = 993
tls = true

# Cache / working directory. Used for the embedded bbolt store AND for staging
# OUTBOUND attachment uploads (POST /v1/attachments) before a message is sent.
# Defaults to "./cache" when omitted; set it to a writable, persistent path.
# If this points nowhere writable, composing with attachments fails with a 503
# "attachment staging unavailable" while reading/downloading attachments still
# works — which looks like "attachments are broken" but is a config issue.
[cache]
folder = "./cache"

# Durable key-value store for caches and shared state (thread metadata,
# recipients, push subscriptions). Optional — omit this whole section to use the
# default embedded bbolt backend (single binary, no external services).
# Set backend = "postgres" only when several instances must share one store, or
# when another Vulos service needs to read the same data.
[storage]
backend = "bolt"   # "bolt" (default) | "postgres"
# postgres_dsn = "postgres://user:password@localhost:5432/lilmail?sslmode=require"

[jwt]
secret = "your-secure-jwt-secret"

[encryption]
key = "your-32-character-encryption-key"

[smtp]
# If not specified, SMTP server will be derived from IMAP server
server = "mail.example.com"
port = 587
use_starttls = true


[ssl]
enabled = true
cert_file = "/etc/letsencrypt/live/yourdomain.com/fullchain.pem"
key_file = "/etc/letsencrypt/live/yourdomain.com/privkey.pem"
port = 443
http_port = 80
auto_redirect = true
domain = "yourdomain.com"
hsts_max_age = 31536000  # 1 year in seconds

# Optional: OAuth2 / OpenID Connect login. When enabled, a "Sign in with
# OAuth2" button appears on the login page. The access token is presented to
# IMAP and SMTP using the XOAUTH2 or OAUTHBEARER SASL mechanism. Password login
# keeps working when this is disabled.
[oauth2]
enabled = false
client_id = "lilmail"
client_secret = "your-oauth2-client-secret"      # leave empty for public PKCE clients
auth_url = "https://auth.example.com/application/o/authorize/"
token_url = "https://auth.example.com/application/o/token/"
# Optional. Used to look up the user's email. If omitted, the email is read
# from the id_token (request the "openid email" scopes).
userinfo_url = "https://auth.example.com/application/o/userinfo/"
redirect_url = "https://yourdomain.com/auth/oauth/callback"
scopes = ["openid", "email", "profile"]
mechanism = "xoauth2"     # "xoauth2" or "oauthbearer"
email_claim = "email"     # claim holding the email address
use_pkce = true           # PKCE (S256); recommended

# Optional: Phase-6 real-time notifications. Everything below is OPT-IN and
# DEFAULT-DISABLED. With enabled = false (the default) the application behaves
# exactly as before — no extra goroutines, no SSE route, no JS changes.
#
# SSE + browser notifications (while a tab is open):
#   1. Set enabled = true.
#   2. Restart the server.
#   3. Open LilMail; grant Notification permission when prompted.
#
# Web Push (background, even with no open tab) — requires HTTPS:
#   4. Set webpush = true.  A VAPID key pair is auto-generated on first start
#      and persisted to vapid_key_file (default: vapid.json in the working dir).
#   5. Go to Settings → Push Notifications → "Enable push notifications".
#
# [notifications]
# enabled       = false   # master switch — must be true to activate anything
# idle          = true    # IMAP IDLE watcher (recommended; falls back to NOOP poll)
# desktop       = false   # native OS toast via gen2brain/beeep (local/desktop runs)
# webpush       = false   # VAPID Web Push — background notifications; needs HTTPS
# vapid_key_file = "vapid.json"  # path for persisted VAPID key pair (auto-generated)

# Optional: CalDAV calendar integration. Routes appear in the sidebar only when enabled.
#
# [caldav]
# enabled  = true
# url      = "https://cal.example.com/dav/"   # CalDAV endpoint or principal URL
# auth     = "basic"                           # "basic" or "oauth2"
# username = "alice@example.com"               # used when auth = "basic"
# password = "app-password"                    # used when auth = "basic"

# Optional: CardDAV address-book for recipient autocomplete in the compose modal.
# When enabled, the To/CC autocomplete also queries the configured address book.
#
# [carddav]
# enabled  = false
# url      = "https://dav.example.com"
# username = "alice@example.com"
# password = "secret"

# Optional: Mail AI assistant. Routes:
#   POST /api/ai/compose         — smart compose / continue / rewrite
#   POST /api/ai/summarize       — thread summary + key points + action items
#   POST /api/ai/reply           — 3 reply suggestions (concise / detailed / decline)
#   POST /api/ai/extract-actions — action items with optional due dates
#   POST /api/ai/phishing        — phishing / suspicious / clean classification
#
# All routes are gated on [ai] enabled. When false they return 404 {"error":"ai_disabled"}.
#
# The default endpoint is the Vulos OS airouter (/api/ai/chat) — no extra
# configuration needed when LilMail is embedded in a Vulos installation.
# For standalone use, point at any OpenAI-compatible SSE chat-completion API.
#
# [ai]
# enabled  = false
# endpoint = "http://localhost:8080/api/ai/chat"  # Vulos OS airouter (default)
# api_key  = ""    # Bearer token — leave empty for local Vulos airouter
# model    = ""    # model slug forwarded to endpoint; empty = endpoint default

# Optional: per-IP rate limits for brute-force / abuse protection.
# All limits are sane-defaulted in code; this section is purely for override.
#
# [rate_limit]
# login_max    = 10    # POST /login — attempts per window per source IP
# login_window = 60    # window in seconds
# send_max     = 30    # POST /v1/messages (send) — messages per window per IP
# send_window  = 60
# ai_max       = 20    # /api/ai/* routes — requests per window per IP
# ai_window    = 60

# Optional: Multi-account support. When enabled, users can add and switch
# between multiple IMAP/SMTP accounts from the Settings page (GET /settings).
# Credentials for each additional account are validated on add and stored
# encrypted (AES-256-GCM, same key as session credentials) in a bbolt database.
#
# Routes added when enabled:
#   GET    /api/accounts              — list additional accounts (no passwords)
#   POST   /api/accounts              — add an account (validates IMAP credentials)
#   DELETE /api/accounts/:email       — remove an account
#   POST   /api/accounts/:email/switch — switch the active session to this account
#
# Unified inbox:
#   Once accounts are added, a "Unified" toggle appears in the inbox toolbar.
#   Clicking it fans out to all accounts concurrently and merges results sorted
#   newest-first. Each row shows a colour badge from the account's configured
#   colour. One failing account does not break the others — a per-account error
#   indicator appears in the toolbar instead.
#   Access directly: GET /inbox?unified=1
#   HTMX partial:    GET /api/folder/INBOX/emails?unified=1
#   Reply/send from a unified-view message uses the correct account's SMTP
#   credentials automatically (pass account_email in the compose form).
#
# [accounts]
# enabled    = false          # master switch; default false
# store_file = "accounts.db"  # bbolt database for encrypted extra-account creds
